# Copy this file to .env.local and fill in your own values.

# Required — see docs/SUPABASE_SETUP.md. Project Settings > API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — only needed for the admin "Upload Photo" buttons. See docs/CLOUDFLARE_R2_SETUP.md.
VITE_UPLOAD_WORKER_URL=https://thayyalkkari-uploads.YOUR-SUBDOMAIN.workers.dev
VITE_UPLOAD_TOKEN=paste-the-same-long-random-string-you-set-with-wrangler-secret-put
